# ===========================================
# GreenOps Platform .gitignore
# ===========================================

# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.venv
venv/
env/
__pycache__/

# ── 환경변수 (절대 커밋 금지) ─────────────────
.env
.envrc
*.env.local

# ── Terraform ───────────────────────────────
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/terraform.tfstate
infra/terraform/terraform.tfstate.backup
infra/terraform/*.tfvars
infra/terraform/crash.log

# ── Docker ──────────────────────────────────
docker-compose.override.yml

# ── Prometheus / Grafana 로컬 데이터 ─────────
infra/prometheus/data/
grafana/data/

# ── Carbon Aware SDK 로컬 설정 ───────────────
infra/carbon-aware-sdk/appsettings.local.json

# Carbon Aware SDK 실제 API 키 (secret.yaml.template을 복사해서 사용)
infra/manifests/carbon-aware-sdk/secret.yaml

# ── IDE ─────────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS ──────────────────────────────────────
.DS_Store
Thumbs.db

# ── 로그 ────────────────────────────────────
*.log
logs/
